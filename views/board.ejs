<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="<%= basePath %>/stylesheets/style.css">
    <style>
        /* ==========================================================================
   1. 글쓰기 버튼 스타일 ([글쓰기])
   ========================================================================== */
        a[href="./board/new"] {
            display: inline-block;
            margin: 30px 40px 15px 40px; /* 헤더 및 리스트와의 간격 정렬 */
            padding: 8px 20px;
            color: #0b0c10;             /* 다크 배경과 대비되는 어두운 글자 */
            background-color: #d4af37;  /* 메인 클래식 골드 */
            font-weight: bold;
            text-decoration: none;
            border-radius: 4px;
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        a[href="/board/new"]:hover {
            background-color: #f3e5ab;  /* 호버 시 더 밝은 골드로 변경 */
            box-shadow: 0 0 18px rgba(243, 229, 171, 0.6); /* 네온 글로우 효과 강화 */
            transform: translateY(-2px);
        }

        /* ==========================================================================
           2. 게시글 목록 스타일 (UL, LI)
           ========================================================================== */
        ul {
            list-style: none;
            padding: 0;
            margin: 0 40px 50px 40px; /* 푸터 전까지 여백 확보 */
            display: flex;
            flex-direction: column;
            gap: 12px; /* 게시글 간의 간격 */
        }

        li {
            display: flex !important;
            align-items: center;
            justify-content: space-between; /* 좌측 제목과 우측 정보 그룹을 양끝으로 갈라놓음 */
            background-color: #11141a;
            border-left: 3px solid rgba(212, 175, 55, 0.4);
            padding: 15px 20px;
            border-radius: 0 6px 6px 0;
            transition: all 0.2s ease;
        }

        /* 게시글 자체에 마우스를 올렸을 때 전체적으로 들어오는 미세한 네온 불빛 */
        li:hover {
            border-left-color: #d4af37;
            background-color: #161a22; /* 살짝 더 밝아지는 배경 */
            box-shadow: 0 0 12px rgba(212, 175, 55, 0.08);
        }

        /* ==========================================================================
           3. 게시글 링크 및 텍스트 스타일
           ========================================================================== */
        /* 게시글 제목 링크 */
        li > a {
            color: #c5c6c7;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;

            /* 제목이 너무 길어지면 우측 영역을 침범하지 않고 말줄임(...) 처리 */
            flex-grow: 1;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 60%; /* 우측 정보창과 겹치지 않도록 최대 가로폭 제한 */
        }

        li > a:hover {
            color: #f3e5ab; /* 호버 시 글자가 부드러운 골드로 빛남 */
            text-shadow: 0 0 5px rgba(243, 229, 171, 0.3);
        }

        /* ==========================================================================
           4. 작업 버튼 영역 (수정 / 삭제 관리)
           ========================================================================== */
        /* ( 수정 / 삭제 ) 전체를 감싸는 텍스트 영역 */
        li, li span.disabled {
            color: #4a4b4c; /* 괄호() 및 슬래시(/)는 톤다운된 회색 처리 */
            font-size: 0.9rem;
        }

        /* 활성화된 수정, 삭제 링크 */
        li a[href*="/board/edit/"],
        li a[href*="/board/delete/"] {
            color: #d4af37;
            text-decoration: none;
            margin: 0 4px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        li a[href*="/board/edit/"]:hover,
        li a[href*="/board/delete/"]:hover {
            color: #ffffff;
            text-shadow: 0 0 8px #d4af37;
        }

        /* 비활성화된 버튼 스타일 (이미 ejs에 클래스가 있으므로 스타일만 보완) */
        .disabled {
            color: #4a4b4c !important; /* 화면에서 완전히 죽어있는 듯한 다크 회색 */
            opacity: 0.4 !important;
            pointer-events: none;
            cursor: not-allowed;
            margin: 0 4px;
        }

        .info {
            margin-left: auto; /* 🌟 핵심: 왼쪽 마진을 auto로 주면 제목 바로 옆이 아니라 우측 끝으로 밀려납니다 */
            margin-right: 15px; /* 바로 옆에 붙는 (수정/삭제) 버튼과의 간격 확보 */
            color: #8f9aa6;
            font-size: 0.9rem;
            white-space: nowrap; /* 해상도가 줄어들어도 작성일이 밑으로 떨어지지 않게 고정 */
        }

        .edit-form {
            color: #4a4b4c;
            font-size: 0.9rem;
            white-space: nowrap;
        }

    </style>
</head>
<body>
<%- include('header') %>
<div style="display: flex; justify-content: flex-end; margin-right: 40px;">
    <a href="./board/new" >글쓰기</a>
</div>
<ul>
    <% posts.forEach(post=>{%>
    <li style="margin-left:<%=post.parent_id ? '30px' : '0'%>">
        <a href="./board/view/<%=post.id%>">
            <%= post.parent_id ? '[답글]': ''%><%= post.title%>
        </a>
        <span class="info"><%=post.author%> <%= post.created_at%></span>
        <% const isAuthor = user && user.username === post.author; %>
        <% const isAdmin = user && user.isAdmin === 1;%>
        <% const isAnon = user && user.username === '익명'; %>

        <span class="edit-form">
        (
            <% if(!isAnon && (isAdmin || isAuthor)) { %>
                <a href="./board/edit/<%= post.id%>">수정</a>
                /
                <a href="./board/delete/<%= post.id %>" onclick="return confirm('정말 삭제하시겠습니까?')">삭제</a>
            <% } else { %>
                <span class="disabled">수정</span>
                /
                <span class="disabled">삭제</span>
            <% } %>
        )
        </span>
    </li>
    <%})%>
</ul>
<%- include('footer') %>
</body>

</html>