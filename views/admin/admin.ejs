<!DOCTYPE html>
<html lang="ko">
<head>
    <title>운영자 메뉴</title>
    <link rel="stylesheet" href="<%= basePath %>/stylesheets/style.css">
    <style>
        body > section {
            max-width: 600px;
            margin: 60px auto;
            padding: 0 20px;
            text-align: center;
        }

        /* 2. 마이페이지 타이틀이 명시되지 않은 구조이므로, section 상단에 사이버펑크 레드 후광 데코레이션 주입 */
        body > section::before {
            display: block;
            font-size: 1.4rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: 2px;
            margin-bottom: 35px;
            text-shadow: 0 0 12px rgba(255, 0, 85, 0.4); /* 골드 ➔ 네온 레드 반영 */
            border-bottom: 2px solid #ff0055; /* 골드 ➔ 운영자 레드 반영 */
            padding-bottom: 15px;
        }

        /* 3. 투박한 기본 <ul> 리스트 제거 및 세로형 메뉴 스택 배치 */
        body > section > ul {
            list-style: none !important;
            padding: 0 !important;
            margin: 0 !important;
            display: flex;
            flex-direction: column;
            gap: 16px; /* 메뉴 카드 간의 완벽한 간격 조율 */
        }

        /* 4. <li> 요소를 개별 클릭 가능한 고급 메탈릭 다크 카드로 커스텀 */
        body > section > ul > li {
            background: #11141a !important; /* 기존 style.css의 시그니처 다크 그레이 */
            border: 1px solid rgba(255, 255, 255, 0.05) !important;
            border-left: 4px solid rgba(255, 0, 85, 0.4) !important; /* 좌측 클래식 골드 ➔ 운영자 레드 포인트선 반영 */
            border-radius: 4px 8px 8px 4px;
            padding: 0 !important; /* 패딩을 0으로 만들어 내부 <a> 태그의 클릭 영역을 극대화 */
            margin: 0 !important;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
        }

        /* 5. <li> 카드 내부의 링크(<a>) 글꼴 확장 및 호버 범위 100% 동기화 */
        body > section > ul > li > a {
            display: block; /* 🌟 중요: 텍스트가 아닌 카드 전체 영역을 누를 수 있게 전환 */
            padding: 20px 25px;
            color: #cbd5e1 !important;
            font-size: 1.1rem;
            font-weight: 600;
            text-decoration: none !important;
            text-align: left; /* 글자 좌측 정렬 */
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            position: relative;
        }

        /* 6. 각 메뉴 우측 끝에 은은한 하이테크 화살표(→) 아이콘 가상 주입 */
        body > section > ul > li > a::after {
            content: "→";
            position: absolute;
            right: 25px;
            top: 50%;
            transform: translateY(-50%);
            color: #4a5568;
            font-size: 1.2rem;
            transition: all 0.2s ease;
        }

        /* ==========================================================================
           ⚡ 인텔리전트 마우스 마이크로 상호작용 (Hover Interaction)
           ========================================================================== */

        /* 카드가 떠오르며 레드 테두리가 네온처럼 발광하는 연출 */
        body > section > ul > li:hover {
            border-left-color: #ff0055 !important; /* 골드 ➔ 운영자 레드 반영 */
            border-color: rgba(255, 0, 85, 0.2) !important; /* 골드 ➔ 운영자 레드 반영 */
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5), 0 0 12px rgba(255, 0, 85, 0.1); /* 글로우 효과 색상 치환 */
        }

        /* 호버 시 텍스트가 붉은빛으로 물들고 우측 화살표가 밖으로 튕겨 나가는 모션 */
        body > section > ul > li:hover > a {
            color: #ff3377 !important; /* 은은한 네온 레드 텍스트 톤 반영 */
            text-shadow: 0 0 8px rgba(255, 0, 85, 0.3); /* 글로우 효과 색상 치환 */
        }

        body > section > ul > li:hover > a::after {
            color: #ff0055; /* 골드 ➔ 운영자 레드 반영 */
            right: 20px; /* 화살표가 우측으로 스르륵 움직이는 이펙트 */
        }

        h2 {
            font-size: 1.6rem;
            color: #ffffff; /* 레드 테마와 조화롭도록 연골드 빛에서 선명한 화이트로 튜닝 */
            margin: 30px 40px 15px 40px;
            border-left: 4px solid #ff0055; /* 골드 ➔ 운영자 레드 선 반영 */
            padding-left: 12px;
            text-shadow: 0 0 8px rgba(255, 0, 85, 0.3); /* 골드 ➔ 운영자 레드 글로우 반영 */
        }
    </style>
</head>
<body>
<%- include('../header') %>
<section>
    <h2>관리자 메뉴</h2>
    <ul>
        <li>
            <a href="./admin/products">상품 관리</a>
        </li>
        <li>
            <a href="./admin/orders">주문 관리</a>
        </li>
        <li>
            <a href="./admin/users">회원 관리</a>
        </li>
    </ul>
</section>
</body>
<%- include('../footer') %>
</html>
