<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>로그인 실패</title>
    <link rel="stylesheet" href="<%= basePath %>/stylesheets/style.css">
    <style>
        body {
            font-family: sans-serif;
            text-align: center;
            padding: 50px;
        }
        .icon-button {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            font-size: 16px;
            text-decoration: none;
            background-color: #ff0055;
            color: black;
            border-radius: 8px;
            transition: background-color 0.3s;
        }
        .icon-button:hover {
            background-color: #ff0055;
        }
        .icon-button span {
            margin-right: 8px;
        }
    </style>
</head>
<body>
<h2><%= message %></h2>

<a class="icon-button" href="./login">다시 로그인하기</a>
</body>
</html>